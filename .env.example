# Supabase — copy to `.env.local` and fill in values from:
# Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

# Public (safe to expose in the browser — used by @supabase/supabase-js on the client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example-replace-with-your-anon-key

# Used for email confirmation redirect (Auth → URL Configuration can also set Site URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — never commit real values; never prefix with NEXT_PUBLIC_
# Optional: enables server-side profile reads when RLS blocks SELECT on `profiles` for the anon client
# (e.g. admin navbar + /admin layout still resolve `profiles.role`).
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example-replace-with-service-role-key
